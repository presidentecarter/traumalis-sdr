{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["index.ts", "api/**/*.ts", "scripts/**/*.ts", "agent/**/*.ts", "src/**/*.ts"]
}
